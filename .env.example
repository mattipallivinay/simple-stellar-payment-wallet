# Stellar Testnet Horizon server (public, free — no key required)
VITE_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Network passphrase — this is what tells Freighter/Stellar SDK
# "sign this transaction for Testnet, not Mainnet"
VITE_STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

VITE_STELLAR_NETWORK=TESTNET
